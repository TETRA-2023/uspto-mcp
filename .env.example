# PPUBS (Patent Public Search) — no auth required, Phase 1
USPTO_PPUBS_URL=https://ppubs.uspto.gov

# ODP (Open Data Portal) — Phase 2, requires API key from data.uspto.gov
USPTO_ODP_URL=https://api.uspto.gov
# USPTO_ODP_API_KEY=your_odp_key_here

# Transport mode: stdio (default), sse, or streamable-http
USPTO_TRANSPORT=stdio

# Optional: when set under HTTP transports (streamable-http / sse), every
# request must present 'Authorization: Bearer <token>'. No-op for stdio.
# MCP_BEARER_TOKEN=replace_with_a_random_secret
